<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>io.goodkind.gha-broker-watchdog</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/gha-broker-watchdog.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>10</integer>
  <key>StandardOutPath</key>
  <string>/var/log/gha-broker-watchdog.log</string>
  <key>StandardErrorPath</key>
  <string>/var/log/gha-broker-watchdog.log</string>
</dict>
</plist>
